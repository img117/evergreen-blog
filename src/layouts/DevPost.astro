---
import type { CollectionEntry } from 'astro:content';
import { BaseHead, Backlinks, Footer, FormattedDate } from '@components/index';
import { useTranslations } from '../i18n/utils';
import '@fontsource-variable/noto-serif-kr';

const { title, pubDate, updatedDate, lang } = Astro.props.frontmatter;
const t = useTranslations("en");
type Props = CollectionEntry<'note'>['data'];

---

<html lang="en">
	<head>
		<BaseHead title={title} />
		<style lang="scss">
			@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&display=swap');
			
			.title {
				padding-bottom: 3rem;
				line-height: 1;

				& .date,
				& .author {
					font-size: var(--sm);
				}
			}

			.date {
				display: flex;
				font-size: var(--sm);
				margin: 1rem 0 1.5rem;
				color: #555;
			}

			.title h1 {
				font-size: 2rem;
				line-height: 1.25;
				padding-right: 3rem;
				margin-bottom: 1rem;
			}

			.navi {
				display: flex;
				align-items: center;
				justify-content: space-between;
				
				a {
					color: inherit;
					font-weight: 400;
					font-size: var(--sm);
				}

				.by {
					font-size: var(--xs);
				}
			}

			.separator {
				margin: 0 0.5rem;
			}

			.separator:nth-last-child(2) {
				color: #eee;
			}
		</style>
	</head>

	<body>
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							{
								!updatedDate && (
									<FormattedDate date={pubDate} />
								)
							}
							{
								updatedDate && (
									<span class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</span>
								)
							}
						</div>
						<div class="navi">
							<div class="author">
								<span class="by">by</span>
								<a href="/">{t('home.name')}</a>
							</div>
							<div class="navi_item">
								<a href="/dev">{t('home.back')}</a>
							</div>
						</div>
					</div>
					<div class="contents">
						<slot />
					</div>
				</div>
			</article>
			<Backlinks />
		</main>
		<Footer lang={lang} />
	</body>
</html>
